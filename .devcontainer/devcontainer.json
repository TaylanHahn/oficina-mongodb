{
  "name": "Laboratorio MongoDB",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  "forwardPorts": [27017],

  "customizations": {
    "vscode": {
      "extensions": [
        "mongodb.mongodb-vscode"
      ],
      "settings": {
        "workbench.colorTheme": "Default Dark+",
        "files.associations": {
          "*.mongodb.js": "mongodb"
        }
      }
    }
  },

  // Instala MongoDB 7 + mongosh do zero, inicia o serviço e popula o banco
  "postCreateCommand": "bash .devcontainer/setup.sh"
}
