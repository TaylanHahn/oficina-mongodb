{
  "name": "Laboratorio MongoDB",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/mongodb:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "mongodb.mongodb-vscode"
      ],
      "settings": {
        "workbench.colorTheme": "Default Dark+",
        "files.associations": {
          "*.mongodb.js": "mongodb"
        }
      }
    }
  },
  "postCreateCommand": "npm install -g mongosh",
  "postStartCommand": "bash -c 'while ! mongosh --quiet --eval \"1\" > /dev/null 2>&1; do sleep 2; done && mongosh scripts/seed.js'"
}
